# Copy this file to .env when you need to override API endpoints.

# Route benches API (same API Gateway stage as counseling if applicable; no trailing slash)
# VITE_BENCHES_API_BASE=https://k2algu70g6.execute-api.ap-southeast-2.amazonaws.com

# Nearby counseling centers API (API Gateway stage URL, no trailing slash)
# VITE_COUNSELING_API_BASE=https://k2algu70g6.execute-api.ap-southeast-2.amazonaws.com
# Optional search radius in meters (default 90000 so metro users still see CBD listings)
# VITE_COUNSELING_SEARCH_RADIUS_METERS=90000
# Pedestrian / social density for custom routes (POST /score/pedestrian). Dev: use Vite proxy /__social-score/*.
# VITE_SOCIAL_SCORE_API_BASE=https://k2algu70g6.execute-api.ap-southeast-2.amazonaws.com

# Tree canopy shade for custom routes (POST /score/shade). Dev: use Vite proxy /__shade-score/*.
# VITE_SHADE_SCORE_API_BASE=https://k2algu70g6.execute-api.ap-southeast-2.amazonaws.com

# Local dev: Vite proxies /__counseling/* to this base to avoid CORS. Production still needs CORS on API Gateway.
